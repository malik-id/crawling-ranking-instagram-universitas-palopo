PORT=3000

# Token untuk tombol/endpoint update manual.
# Ubah nilainya jika project dipakai online.
UPDATE_TOKEN=kampuspalopo123

# Aktifkan update otomatis dengan cron.
ENABLE_CRON=true

# Default: update setiap 12 jam.
CRON_SCHEDULE=0 */12 * * *

# true = browser tidak terlihat, cocok untuk server.
# false = browser terlihat, cocok untuk debugging lokal.
HEADLESS=true
